generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(cuid())
  locale    String   @default("ru")
  answers   Json
  profile   Json?
  isPaid    Boolean  @default(false)
  paymentId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
