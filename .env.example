# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Supabase, Neon, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/careertest"

# ─── LemonSqueezy ────────────────────────────────────────────────────────────
# Get from: https://app.lemonsqueezy.com/settings/api
LEMONSQUEEZY_API_KEY="eyJ0eXAiOiJKV1..."

# Your store numeric ID (Settings → Stores)
LEMONSQUEEZY_STORE_ID="12345"

# Variant ID of your product (Products → [product] → Variants → ID)
LEMONSQUEEZY_VARIANT_ID="67890"

# Webhook signing secret (Settings → Webhooks → create webhook)
LEMONSQUEEZY_WEBHOOK_SECRET="your_webhook_secret"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="https://yoursite.com"

# ─── Telegram Bot (optional) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="1234567890:AAH..."
