{
  "buildCommand": "node Website/tools/build-site.mjs",
  "outputDirectory": "Website",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/privacy",
      "destination": "/legal/privacy/",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/legal/terms/",
      "permanent": true
    },
    {
      "source": "/delete-data",
      "destination": "/legal/delete-data/",
      "permanent": true
    },
    {
      "source": "/refund-policy",
      "destination": "/refund/",
      "permanent": true
    },
    {
      "source": "/refunds",
      "destination": "/refund/",
      "permanent": true
    }
  ]
}
