# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway, Supabase, Neon, or local)
DATABASE_URL="postgresql://user:password@localhost:5432/careertest"

# ─── Paddle ──────────────────────────────────────────────────────────────────
# Client token (public) — Paddle Dashboard → Developer Tools → Client-side tokens
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="live_xxx"

# Full access price ID — Paddle Dashboard → Catalog → Prices → pri_xxx
NEXT_PUBLIC_PADDLE_PRICE_ID="pri_xxx"

# Single career reveal price ID (cheaper tier)
NEXT_PUBLIC_PADDLE_PRICE_ID_SINGLE="pri_xxx"

# Webhook secret — Paddle Dashboard → Developer Tools → Notifications
PADDLE_WEBHOOK_SECRET="pdl_ntfset_xxx"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_URL="https://mentivo.net"

# ─── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID from GA4 → Admin → Data Streams → your stream → Measurement ID
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ─── Telegram Bot (optional) ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN="1234567890:AAH..."
